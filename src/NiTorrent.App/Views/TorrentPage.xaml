<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NiTorrent.App.Views.TorrentPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:NiTorrent.App.Converters"
    xmlns:mt="using:MonoTorrent.Client"
    xmlns:vm="using:NiTorrent.Presentation.Features.Torrents"
    NavigationCacheMode="Required"
    DataContext="{x:Bind ViewModel, Mode=OneWay}">

    <Page.Resources>
        <ResourceDictionary>
            <converters:TorrentStateToBadgeStyleConverter x:Key="TorrentStateToBadgeStyleConverter"/>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Padding="10" RowSpacing="12">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TeachingTip -->
        <TeachingTip x:Name="MagnetTip"
                    Title="Добавить Magnet ссылку"
                    IsLightDismissEnabled="True"
                    PreferredPlacement="Center"
                    ShouldConstrainToRootBounds="True">

            <StackPanel Spacing="12" Width="300">
                <TextBox x:Name="MagnetInput"
                    PlaceholderText="Вставьте Magnet ссылку..."
                    AcceptsReturn="False"/>

                <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">
                    <Button Content="Отмена" Click="CancelMagnet_Click"/>
                    <Button Content="Добавить" Click="ConfirmMagnet_Click"/>
                </StackPanel>
            </StackPanel>
        </TeachingTip>


        <!-- COMMAND BAR (плитка) -->
        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="8"
                Grid.Row="0">

            <CommandBar DefaultLabelPosition="Right"
                        OverflowButtonVisibility="Collapsed"
                        Background="Transparent">

                <AppBarButton Label="Добавить" Icon="Add">
                    <AppBarButton.Flyout>
                        <MenuFlyout>
                            <MenuFlyoutItem Text="Добавить .torrent файл"
                                            Icon="OpenFile"
                                            Command="{x:Bind ViewModel.PickTorrentCommand}"/>

                            <MenuFlyoutItem Text="Добавить Magnet ссылку"
                                            Icon="Link"
                                            Click="AddMagnet_Click"/>
                        </MenuFlyout>
                    </AppBarButton.Flyout>
                </AppBarButton>

                <AppBarSeparator/>

                <AppBarButton Label="Старт" Icon="Play" Command="{Binding StartCommand}"/>
                <AppBarButton Label="Пауза" Icon="Pause" Command="{Binding PauseCommand}"/>
                <AppBarButton Label="Папка" Icon="Folder" Command="{Binding OpenFolderCommand}"/>

                <AppBarSeparator/>

                <AppBarButton Label="Удалить" Icon="Delete" IsEnabled="{Binding CanRemove}">
                    <AppBarButton.Flyout>
                        <MenuFlyout>
                            <MenuFlyoutItem Text="Удалить"
                                            Icon="Delete"
                                            Command="{Binding RemoveTorrentCommand}"
                                            CommandParameter="{x:Bind mt:RemoveMode.CacheDataOnly}"/>

                            <MenuFlyoutItem Text="Удалить со скачанным"
                                            Icon="Delete"
                                            Command="{Binding RemoveTorrentCommand}"
                                            CommandParameter="{x:Bind mt:RemoveMode.CacheDataAndDownloadedData}"/>
                        </MenuFlyout>
                    </AppBarButton.Flyout>
                </AppBarButton>

            </CommandBar>
        </Border>

        <!-- TABLE TILE -->
        <Border Grid.Row="1"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="0">

            <Grid RowSpacing="0">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- HEADER (меньше и цвет как фон страницы) -->
                <Border Grid.Row="0"
                        Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="6"
                        CornerRadius="8,8,0,0">

                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="ColName" Width="3*"/>
                            <ColumnDefinition x:Name="ColSize" Width="1*"/>
                            <ColumnDefinition x:Name="ColProgress" Width="2*"/>
                            <ColumnDefinition x:Name="ColSpeed" Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Название"
                                   Grid.Column="0"
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                        <TextBlock Text="Размер"
                                   Grid.Column="1"
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                        <TextBlock Text="Прогресс"
                                   Grid.Column="2"
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                        <TextBlock Text="Скорость"
                                   Grid.Column="3"
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </Grid>

                </Border>

                <!-- LIST -->
                <ListView Grid.Row="1"
                          ItemsSource="{Binding Torrents}"
                          SelectedItem="{Binding SelectedTorrent, Mode=TwoWay}"
                          SelectionMode="Single"
                          Background="Transparent"
                          BorderThickness="0"
                          HorizontalContentAlignment="Stretch"
                          SelectionChanged="ListView_SelectionChanged">

                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem"
                               BasedOn="{StaticResource DefaultListViewItemStyle}">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                        </Style>
                    </ListView.ItemContainerStyle>

                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:TorrentItemViewModel">

                            <Grid ColumnSpacing="16"
                                  Padding="8,6">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="{Binding ElementName=ColName, Path=Width}"/>
                                    <ColumnDefinition Width="{Binding ElementName=ColSize, Path=Width}"/>
                                    <ColumnDefinition Width="{Binding ElementName=ColProgress, Path=Width}"/>
                                    <ColumnDefinition Width="{Binding ElementName=ColSpeed, Path=Width}"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0"
                                            Orientation="Horizontal"
                                            Spacing="8"
                                            VerticalAlignment="Center">
                                    <InfoBadge Style="{Binding StatusInfo, Converter={StaticResource TorrentStateToBadgeStyleConverter}}"/>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                </StackPanel>

                                <TextBlock Text="{Binding Size}"
                                           Grid.Column="1"
                                           VerticalAlignment="Center"/>

                                <StackPanel Grid.Column="2">
                                    <ProgressBar Value="{Binding Progress}"
                                                 Height="6"
                                                 Minimum="0"
                                                 Maximum="100"/>
                                    <TextBlock Text="{Binding ProgressText}"
                                               FontSize="12"
                                               Opacity="0.7"/>
                                </StackPanel>

                                <TextBlock Text="{Binding DownloadSpeed}"
                                           Grid.Column="3"
                                           VerticalAlignment="Center"/>

                            </Grid>

                        </DataTemplate>
                    </ListView.ItemTemplate>

                </ListView>

            </Grid>

        </Border>

        <!-- STATUS BAR (плитка) -->
        <Border Grid.Row="2"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12"
                Height="40">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding StatusText}"
                           VerticalAlignment="Center"
                           Opacity="0.8"/>

                <StackPanel Orientation="Horizontal"
                            Grid.Column="1"
                            Spacing="16"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding TotalDownloadSpeed}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding TotalUploadSpeed}" FontWeight="SemiBold"/>
                </StackPanel>
            </Grid>

        </Border>

    </Grid>
</Page>

