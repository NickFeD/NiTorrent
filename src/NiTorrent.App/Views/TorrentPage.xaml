<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NiTorrent.App.Views.TorrentPage"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:NiTorrent.App.Converters"
    xmlns:vm="using:NiTorrent.Presentation.Features.Torrents"
    NavigationCacheMode="Required">

    <Page.Resources>
        <ResourceDictionary>
            <converters:TorrentStateToBadgeStyleConverter x:Key="TorrentStateToBadgeStyleConverter"/>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Padding="12" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header + Toolbar -->
            <RowDefinition Height="*"/>
            <!-- Content -->
        </Grid.RowDefinitions>

        <!-- TeachingTip -->
        <TeachingTip x:Name="MagnetTip"
                     Title="Добавить Magnet ссылку"
                     IsLightDismissEnabled="True"
                     PreferredPlacement="Center"
                     ShouldConstrainToRootBounds="True">
            <StackPanel Spacing="12" Width="320">
                <TextBox x:Name="MagnetInput"
                         PlaceholderText="Вставьте Magnet ссылку…"
                         AcceptsReturn="False"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Spacing="8">
                    <Button Content="Отмена" Click="CancelMagnet_Click"/>
                    <Button Content="Добавить" Click="ConfirmMagnet_Click"/>
                </StackPanel>
            </StackPanel>
        </TeachingTip>

        <!-- HEADER + TOOLBAR (one tile) -->
        <Border Grid.Row="0"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="12">

            <Grid RowSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Title + small status -->
                <Grid Grid.Column="0" ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="2">
                        <TextBlock Text="Torrents"
                                   FontSize="20"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                                   Opacity="0.75"
                                   FontSize="12"
                                   TextTrimming="CharacterEllipsis"
                                   MaxLines="1"/>
                    </StackPanel>
                </Grid>

                <!-- Toolbar -->
                <CommandBar Grid.Column="1"
                            DefaultLabelPosition="Right"
                            OverflowButtonVisibility="Collapsed"
                            Background="Transparent">

                    <AppBarButton Label="Добавить" Icon="Add">
                        <AppBarButton.Flyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="Добавить .torrent файл"
                                                Icon="OpenFile"
                                                Command="{x:Bind ViewModel.PickTorrentCommand}"/>
                                <MenuFlyoutItem Text="Добавить Magnet ссылку"
                                                Icon="Link"
                                                Click="AddMagnet_Click"/>
                            </MenuFlyout>
                        </AppBarButton.Flyout>
                    </AppBarButton>

                    <AppBarSeparator/>

                    <AppBarButton Label="Старт" Icon="Play" Command="{x:Bind ViewModel.StartCommand}"/>
                    <AppBarButton Label="Пауза" Icon="Pause" Command="{x:Bind ViewModel.PauseCommand}"/>
                    <AppBarButton Label="Папка" Icon="Folder" Command="{x:Bind ViewModel.OpenFolderCommand}"/>

                    <AppBarSeparator/>

                    <AppBarButton Label="Удалить"
                                  Icon="Delete"
                                  IsEnabled="{x:Bind ViewModel.CanRemove, Mode=OneWay}">
                        <AppBarButton.Flyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="Удалить"
                                                Icon="Delete"
                                                Command="{x:Bind ViewModel.RemoveTorrentCommand}"
                                                CommandParameter="0"/>
                                <MenuFlyoutItem Text="Удалить со скачанным"
                                                Icon="Delete"
                                                Command="{x:Bind ViewModel.RemoveTorrentCommand}"
                                                CommandParameter="1"/>
                            </MenuFlyout>
                        </AppBarButton.Flyout>
                    </AppBarButton>
                </CommandBar>
            </Grid>
        </Border>

        <!-- CONTENT -->
        <Border Grid.Row="1"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="12">

            <Grid RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- list header -->
                    <RowDefinition Height="*"/>
                    <!-- list/empty -->
                </Grid.RowDefinitions>
                
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <!-- list header -->
                    <TextBlock Grid.Column="0"
                       Text="Список торрентов"
                       FontWeight="SemiBold"
                       Opacity="0.90"/>
                    <!-- Totals -->
                    <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="14"
                        VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE74B;" FontSize="12" Opacity="0.85"/>
                            <TextBlock Text="{x:Bind ViewModel.TotalDownloadSpeed, Mode=OneWay}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Opacity="0.95"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE74A;" FontSize="12" Opacity="0.85"/>
                            <TextBlock Text="{x:Bind ViewModel.TotalUploadSpeed, Mode=OneWay}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Opacity="0.95"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
                

                <!-- list -->
                <Grid Grid.Row="1">
                    <ListView ItemsSource="{x:Bind ViewModel.Torrents, Mode=OneWay}"
                              SelectedItem="{x:Bind ViewModel.SelectedTorrent, Mode=TwoWay}"
                              SelectionMode="Single"
                              Background="Transparent"
                              BorderThickness="0"
                              HorizontalContentAlignment="Stretch"
                              SelectionChanged="ListView_SelectionChanged">

                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem" BasedOn="{StaticResource DefaultListViewItemStyle}">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,10"/>
                                <Setter Property="Background" Value="Transparent"/>
                            </Style>
                        </ListView.ItemContainerStyle>

                        <!-- ТВОИ КАРТОЧКИ -->
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:TorrentItemViewModel">
                                <Border CornerRadius="12"
                                        Padding="12"
                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1">

                                    <Grid RowSpacing="10">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- ROW 1: [Name] [Size] -->
                                        <Grid Grid.Row="0" ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Text="{x:Bind Name}"
                                                       FontWeight="SemiBold"
                                                       FontSize="14"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxLines="1"/>

                                            <TextBlock Grid.Column="1"
                                                       Text="{x:Bind Size}"
                                                       FontSize="12"
                                                       Opacity="0.75"
                                                       VerticalAlignment="Center"/>
                                        </Grid>

                                        <!-- ROW 2: [Status] [DL] [UL] [%] -->
                                        <Grid Grid.Row="1" ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Text="{x:Bind StateText, Mode=OneWay}"
                                                       FontSize="12"
                                                       Opacity="0.85"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxLines="1"/>

                                            <StackPanel Grid.Column="1"
                                                        Orientation="Horizontal"
                                                        Spacing="6"
                                                        VerticalAlignment="Center">
                                                <FontIcon Glyph="&#xE74B;" FontSize="12" Opacity="0.85"/>
                                                <TextBlock Text="{x:Bind DownloadSpeed, Mode=OneWay}"
                                                           FontSize="12"
                                                           Opacity="0.90"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2"
                                                        Orientation="Horizontal"
                                                        Spacing="6"
                                                        VerticalAlignment="Center">
                                                <FontIcon Glyph="&#xE74A;" FontSize="12" Opacity="0.85"/>
                                                <TextBlock Text="{x:Bind UploadSpeed, Mode=OneWay}"
                                                           FontSize="12"
                                                           Opacity="0.90"/>
                                            </StackPanel>

                                            <TextBlock Grid.Column="3"
                                                       Text="{x:Bind ProgressText, Mode=OneWay}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Opacity="0.95"
                                                       VerticalAlignment="Center"/>
                                        </Grid>

                                        <!-- ROW 3: Progress bar -->
                                        <ProgressBar Grid.Row="2"
                                                     Value="{x:Bind Progress, Mode=OneWay}"
                                                     Minimum="0"
                                                     Maximum="100"
                                                     Height="6"
                                                     CornerRadius="3"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Optional empty state (сейчас будет всегда видно; лучше скрывать через Visibility) -->
                    <!--<Grid HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          IsHitTestVisible="False">
                        <StackPanel Spacing="10" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE8B7;" FontSize="28" Opacity="0.70"/>
                            <TextBlock Text="Пока нет торрентов"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Добавьте .torrent файл или magnet-ссылку."
                                       Opacity="0.75"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>-->
                </Grid>

                <Grid Grid.Row="1"  HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    IsHitTestVisible="False"
                    Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay}">
                    <StackPanel Spacing="10" HorizontalAlignment="Center">
                        <FontIcon Glyph="&#xE8B7;" FontSize="28" Opacity="0.70"/>
                        <TextBlock Text="Пока нет торрентов"
                   FontSize="16"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Добавьте .torrent файл или magnet-ссылку."
                   Opacity="0.75"
                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>

            </Grid>
            
        </Border>
    </Grid>
</Page>
