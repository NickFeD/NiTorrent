<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NiTorrent.App.Views.TorrentDetailsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:NiTorrent.Presentation.Features.Torrents"
    NavigationCacheMode="Disabled">

    <ScrollViewer>
        <Grid Padding="12" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="12">
                <StackPanel Spacing="6">
                    <TextBlock Text="Подробности торрента"
                               FontSize="20"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{x:Bind ViewModel.Title, Mode=OneWay}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               TextWrapping="WrapWholeWords"/>
                    <TextBlock Text="{x:Bind ViewModel.StatusLabel, Mode=OneWay}"/>
                    <TextBlock Text="{x:Bind ViewModel.SavePath, Mode=OneWay}"
                               Opacity="0.75"
                               TextWrapping="WrapWholeWords"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="12">
                <StackPanel Spacing="12">
                    <TextBlock Text="Настройки торрента"
                               FontWeight="SemiBold"/>

                    <TextBox Header="Путь загрузки (override)"
                             Text="{x:Bind ViewModel.DownloadPathOverride, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             PlaceholderText="Использовать общий путь"/>

                    <TextBox Header="Максимальная скорость загрузки (B/s)"
                             Text="{x:Bind ViewModel.MaximumDownloadRateText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             PlaceholderText="Без ограничения"/>

                    <TextBox Header="Максимальная скорость отдачи (B/s)"
                             Text="{x:Bind ViewModel.MaximumUploadRateText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             PlaceholderText="Без ограничения"/>

                    <ToggleSwitch Header="Sequential download"
                                  IsOn="{x:Bind ViewModel.SequentialDownload, Mode=TwoWay}"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8">
                <Button Content="Назад" Click="Back_Click"/>
                <Button Content="Сохранить"
                        Command="{x:Bind ViewModel.SaveCommand}"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
