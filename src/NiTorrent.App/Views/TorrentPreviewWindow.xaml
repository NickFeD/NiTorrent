<?xml version="1.0" encoding="utf-8"?>
<winuiEx:WindowEx
    x:Class="NiTorrent.App.Views.TorrentPreviewWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tree="using:NiTorrent.Presentation.Features.Torrents.Tree"
    xmlns:winuiEx="using:WinUIEx"
    xmlns:dev="using:DevWinUI"
    x:Name="RootWindow"
    MinWidth="560"
    MinHeight="520"
    Width="600"
    mc:Ignorable="d">

    <winuiEx:WindowEx.SystemBackdrop>
        <MicaBackdrop />
    </winuiEx:WindowEx.SystemBackdrop>

    <Grid RowDefinitions="Auto,*">
        <!-- TOP BAR -->
        <TitleBar Grid.Row="0" x:Name="AppTitleBar"
            Title="Добавление торрента"
            IsBackButtonVisible="False"
            IsPaneToggleButtonVisible="False">
            <TitleBar.LeftHeader>
                <ImageIcon Width="16"
           Height="16"
           Margin="15,0,14,0"
           Source="ms-appx:///Assets/AppIcon.png" />
            </TitleBar.LeftHeader>
        </TitleBar>


        <!-- CONTENT -->
        <Grid Grid.Row="1"
              x:Name="Root"
              Padding="14"
              RowSpacing="10"
              RowDefinitions="Auto,Auto,*,Auto">

            <!-- INFO CARD -->
            <Border Grid.Row="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="12">
                <StackPanel Spacing="2">
                    <TextBlock Text="{x:Bind ViewModel.Name, Mode=OneWay}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"
                               MaxLines="2"/>

                    <TextBlock Text="{x:Bind ViewModel.Size, Mode=OneWay}"
                               FontSize="12"
                               Opacity="0.75"/>
                </StackPanel>
            </Border>

            <!-- SAVE PATH CARD -->
            <Border Grid.Row="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="12">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Путь сохранения"
                               FontWeight="SemiBold"
                               Opacity="0.90"/>

                    <Grid Grid.Row="1"
                          ColumnDefinitions="*,Auto"
                          ColumnSpacing="8">

                        <TextBox Text="{x:Bind ViewModel.OutputFolder, Mode=TwoWay}"
                                 PlaceholderText="Выберите папку…"
                                 VerticalAlignment="Center"/>

                        <Button Grid.Column="1"
                                Content="Выбрать"
                                VerticalAlignment="Center"
                                Click="PickFolder_Click"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- FILES CARD -->
            <Border Grid.Row="2"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="12">
                <Grid RowSpacing="8" RowDefinitions="Auto,*">
                    <TextBlock Grid.Row="0"
                               Text="Файлы"
                               FontWeight="SemiBold"
                               Opacity="0.90"/>

                    <!-- Scroll to keep layout stable -->
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <TreeView x:Name="FilesTreeView"
                                  ItemsSource="{x:Bind ViewModel.RootItems, Mode=OneWay}"
                                  Expanding="FilesTreeView_Expanding"
                                  CanDragItems="False"
                                  CanReorderItems="False"
                                  AllowDrop="False"
                                  SelectionMode="None">

                            <TreeView.ItemTemplate>
                                <DataTemplate x:DataType="tree:TorrentTreeItemViewModel">
                                    <TreeViewItem ItemsSource="{x:Bind Children}">
                                        <TreeViewItem.Content>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <CheckBox IsThreeState="True"
                                                          MinWidth="2"
                                                          IsEnabled="{x:Bind CanToggle}"
                                                          IsChecked="{x:Bind IsChecked, Mode=OneWay}"
                                                          Command="{x:Bind ToggleCommand}"
                                                          x:SuppressXamlTrimWarnings="True"
                                                          CommandParameter="{Binding IsChecked, RelativeSource={RelativeSource Mode=Self}}"/>

                                                <FontIcon Glyph="{x:Bind TypeGlyph}"
                                                          FontSize="14"
                                                          Opacity="0.85"/>

                                                <TextBlock Text="{x:Bind Name}"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxLines="1"/>
                                            </StackPanel>
                                        </TreeViewItem.Content>
                                    </TreeViewItem>
                                </DataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- BUTTONS -->
            <Border Grid.Row="3"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="10">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Spacing="8">
                    <Button Content="Отмена" Click="Cancel_Click"/>
                    <Button Content="OK"
                            Click="Ok_Click"
                            Style="{ThemeResource AccentButtonStyle}"/>
                </StackPanel>
            </Border>

        </Grid>
    </Grid>
</winuiEx:WindowEx>
