<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="NiTorrent.App.Views.TorrentPreviewWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tree="using:NiTorrent.Presentation.Features.Torrents.Tree"
    xmlns:local="using:NiTorrent.App.Converters"
    mc:Ignorable="d"
    Title="Добавление торрента">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="Root" Padding="24" RowSpacing="20"
          RowDefinitions="Auto,Auto,*,Auto">
    
        <!-- HEADER -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="{Binding Name}"
                       FontSize="24"
                       FontWeight="SemiBold"/>

            <TextBlock Text="{Binding Size}"
                       FontSize="14"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <!-- SAVE PATH -->
        <Grid Grid.Row="1"
              ColumnDefinitions="Auto,*,Auto"
              ColumnSpacing="12">

            <TextBlock Text="Путь сохранения:"
                       VerticalAlignment="Center"/>

            <TextBox Grid.Column="1"
                     Text="{Binding OutputFolder, Mode=TwoWay}"
                     PlaceholderText="Выберите папку..."
                     VerticalAlignment="Center"/>

            <Button Grid.Column="2"
                    Content="..."
                    VerticalAlignment="Center"
                    Click="PickFolder_Click"/>
        </Grid>


        <TreeView Grid.Row="2"
                  x:Name="FilesTreeView"
                  ItemsSource="{x:Bind ViewModel.RootItems}"
                  Expanding="FilesTreeView_Expanding"
                  CanDragItems="False"
                  CanReorderItems="False"
                  AllowDrop="False"
                  SelectionMode="None">

            <TreeView.ItemTemplate>
                <DataTemplate x:DataType="tree:TorrentTreeItemViewModel">
                    <TreeViewItem ItemsSource="{x:Bind Children}">
                        <TreeViewItem.Content>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <CheckBox IsThreeState="True"
                                          IsEnabled="{x:Bind CanToggle}"
                                          IsChecked="{x:Bind IsChecked, Mode=TwoWay}"
                                          VerticalAlignment="Center" />

                                <TextBlock Text="{x:Bind Name}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </TreeViewItem.Content>
                    </TreeViewItem>
                </DataTemplate>
            </TreeView.ItemTemplate>

        </TreeView>

        <!-- BUTTONS -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="12">

            <Button Content="Отмена"
                    Click="Cancel_Click"/>

            <Button Content="OK"
                    Click="Ok_Click"/>
        </StackPanel>

    </Grid>
</Window>

