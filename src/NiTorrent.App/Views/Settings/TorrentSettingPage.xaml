<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NiTorrent.App.Views.TorrentSettingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dev="using:DevWinUI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    dev:BreadcrumbNavigator.IsHeaderVisible="True">

    <ScrollView Margin="{ThemeResource ContentPageMargin}"
                Padding="{ThemeResource ContentPagePadding}"
                VerticalScrollBarVisibility="Auto">

        <StackPanel Margin="10"
                    dev:PanelAttach.ChildrenTransitions="Default"
                    Spacing="5">

            <!-- Папка -->
            <dev:SettingsCard Header="Папка загрузки"
                              Description="Путь по умолчанию для новых торрентов и окна предпросмотра."
                              HeaderIcon="{dev:BitmapIcon Source=Assets/Fluent/Info.png}">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <TextBox MinWidth="320"
                             Text="{x:Bind ViewModel.DefaultDownloadPath, Mode=TwoWay}"
                             PlaceholderText="Выберите папку…"/>

                    <Button Grid.Column="1"
                            MinWidth="{StaticResource SettingActionControlMinWidth}"
                            Content="Выбрать"
                            Command="{x:Bind ViewModel.BrowseDefaultPathCommand}"/>
                </Grid>
            </dev:SettingsCard>

            <!-- Скорость -->
            <dev:SettingsExpander Header="Скорость"
                                  Description="Лимиты в KiB/s. 0 — без ограничений."
                                  HeaderIcon="{dev:BitmapIcon Source=Assets/Fluent/Update.png}"
                                  IsExpanded="True">

                <dev:SettingsExpander.Items>
                    <dev:SettingsCard Header="Ограничение загрузки">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <NumberBox MinWidth="200"
                                       Value="{x:Bind ViewModel.DownloadRateValue, Mode=TwoWay}"
                                       Minimum="0"
                                       SmallChange="1"
                                       SpinButtonPlacementMode="Compact" />
                            <ComboBox Grid.Column="1"
                                      MinWidth="90"
                                      ItemsSource="{x:Bind ViewModel.Units}"
                                      SelectedItem="{x:Bind ViewModel.SelectedDownloadUnit, Mode=TwoWay}" />
                        </Grid>
                    </dev:SettingsCard>

                    <dev:SettingsCard Header="Ограничение выгрузки">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <NumberBox MinWidth="200"
                                       Value="{x:Bind ViewModel.UploadRateValue, Mode=TwoWay}"
                                       Minimum="0"
                                       SmallChange="1"
                                       SpinButtonPlacementMode="Compact" />
                            <ComboBox Grid.Column="1"
                                      MinWidth="90"
                                      ItemsSource="{x:Bind ViewModel.Units}"
                                      SelectedItem="{x:Bind ViewModel.SelectedUploadUnit, Mode=TwoWay}" />
                        </Grid>
                    </dev:SettingsCard>
                </dev:SettingsExpander.Items>
            </dev:SettingsExpander>

            <!-- Диск -->
            <dev:SettingsExpander Header="Диск"
                                  Description="Ограничения чтения/записи. 0 — без ограничений."
                                  HeaderIcon="{dev:BitmapIcon Source=Assets/Fluent/Backdrop.png}"
                                  IsExpanded="False">

                <dev:SettingsExpander.Items>
                    <dev:SettingsCard Header="Ограничение чтения">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <NumberBox MinWidth="200"
                                       Value="{x:Bind ViewModel.DiskReadRateValue, Mode=TwoWay}"
                                       Minimum="0"
                                       SmallChange="1"
                                       SpinButtonPlacementMode="Compact" />
                            <ComboBox Grid.Column="1"
                                      MinWidth="90"
                                      ItemsSource="{x:Bind ViewModel.Units}"
                                      SelectedItem="{x:Bind ViewModel.SelectedDiskReadUnit, Mode=TwoWay}" />
                        </Grid>
                    </dev:SettingsCard>

                    <dev:SettingsCard Header="Ограничение записи">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <NumberBox MinWidth="200"
                                       Value="{x:Bind ViewModel.DiskWriteRateValue, Mode=TwoWay}"
                                       Minimum="0"
                                       SmallChange="1"
                                       SpinButtonPlacementMode="Compact" />
                            <ComboBox Grid.Column="1"
                                      MinWidth="90"
                                      ItemsSource="{x:Bind ViewModel.Units}"
                                      SelectedItem="{x:Bind ViewModel.SelectedDiskWriteUnit, Mode=TwoWay}" />
                        </Grid>
                    </dev:SettingsCard>
                </dev:SettingsExpander.Items>
            </dev:SettingsExpander>

            <!-- Сеть -->
            <dev:SettingsExpander Header="Сеть"
                                  Description="Настройки обнаружения пиров и автоматической конфигурации."
                                  HeaderIcon="{dev:BitmapIcon Source=Assets/Fluent/Color.png}"
                                  IsExpanded="False">

                <dev:SettingsExpander.Items>
                    <dev:SettingsCard Header="DHT">
                        <ToggleSwitch IsOn="{x:Bind ViewModel.AllowDht, Mode=TwoWay}"
                                      OnContent="Вкл."
                                      OffContent="Выкл." />
                    </dev:SettingsCard>

                    <dev:SettingsCard Header="Port Forwarding">
                        <ToggleSwitch IsOn="{x:Bind ViewModel.AllowPortForwarding, Mode=TwoWay}"
                                      OnContent="Вкл."
                                      OffContent="Выкл." />
                    </dev:SettingsCard>

                    <dev:SettingsCard Header="Local Peer Discovery">
                        <ToggleSwitch IsOn="{x:Bind ViewModel.AllowLocalPeerDiscovery, Mode=TwoWay}"
                                      OnContent="Вкл."
                                      OffContent="Выкл." />
                    </dev:SettingsCard>
                </dev:SettingsExpander.Items>
            </dev:SettingsExpander>

            <!-- Дополнительно -->
            <dev:SettingsExpander Header="Дополнительно"
                                  Description="Ограничения соединений и поведение сохранения состояния."
                                  HeaderIcon="{dev:BitmapIcon Source=Assets/Fluent/Theme.png}"
                                  IsExpanded="False">

                <dev:SettingsExpander.Items>
                    <dev:SettingsCard Header="Max connections">
                        <NumberBox MinWidth="200"
                                   Value="{x:Bind ViewModel.MaximumConnections, Mode=TwoWay}"
                                   Minimum="1"
                                   SmallChange="10"
                                   SpinButtonPlacementMode="Compact" />
                    </dev:SettingsCard>

                    <dev:SettingsCard Header="Max open files">
                        <NumberBox MinWidth="200"
                                   Value="{x:Bind ViewModel.MaximumOpenFiles, Mode=TwoWay}"
                                   Minimum="1"
                                   SmallChange="10"
                                   SpinButtonPlacementMode="Compact" />
                    </dev:SettingsCard>

                    <dev:SettingsCard Header="Auto Save/Load FastResume">
                        <ToggleSwitch IsOn="{x:Bind ViewModel.AutoSaveLoadFastResume, Mode=TwoWay}"
                                      OnContent="Вкл."
                                      OffContent="Выкл." />
                    </dev:SettingsCard>

                    <dev:SettingsCard Header="Auto Save/Load Magnet Metadata">
                        <ToggleSwitch IsOn="{x:Bind ViewModel.AutoSaveLoadMagnetLinkMetadata, Mode=TwoWay}"
                                      OnContent="Вкл."
                                      OffContent="Выкл." />
                    </dev:SettingsCard>

                    <dev:SettingsCard Header="FastResume mode">
                        <ComboBox MinWidth="200"
                                  ItemsSource="{x:Bind ViewModel.FastResumeModes}"
                                  SelectedItem="{x:Bind ViewModel.SelectedFastResumeMode, Mode=TwoWay}" />
                    </dev:SettingsCard>
                </dev:SettingsExpander.Items>
            </dev:SettingsExpander>

            <!-- Действия -->
            <dev:SettingsCard Header="Действия"
                              Description="Изменения применяются после сохранения."
                              HeaderIcon="{dev:BitmapIcon Source=Assets/Fluent/Update.png}">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Spacing="10">
                    <Button MinWidth="{StaticResource SettingActionControlMinWidth}"
                            Content="Перезагрузить"
                            Command="{x:Bind ViewModel.ReloadCommand}" />
                    <Button MinWidth="{StaticResource SettingActionControlMinWidth}"
                            Content="Применить"
                            Style="{ThemeResource AccentButtonStyle}"
                            Command="{x:Bind ViewModel.SaveCommand}" />
                </StackPanel>
            </dev:SettingsCard>

        </StackPanel>
    </ScrollView>
</Page>
